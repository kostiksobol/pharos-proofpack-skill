{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pharos ProofPack",
  "description": "Machine-checkable evidence pack generated by pharos-proofpack-skill.",
  "type": "object",
  "required": [
    "proofpackVersion",
    "tool",
    "generatedAt",
    "network",
    "command",
    "claim",
    "evidence",
    "conclusion",
    "packHash"
  ],
  "properties": {
    "proofpackVersion": {
      "type": "string"
    },
    "tool": {
      "const": "pharos-proofpack-skill"
    },
    "generatedAt": {
      "type": "string"
    },
    "network": {
      "type": "object",
      "required": [
        "name",
        "chainId",
        "rpcUrl",
        "explorerUrl",
        "nativeToken"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "chainId": {
          "type": "number"
        },
        "rpcUrl": {
          "type": "string"
        },
        "explorerUrl": {
          "type": "string"
        },
        "nativeToken": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "command": {
      "type": "string",
      "enum": [
        "prove-chain",
        "prove-tx",
        "prove-contract",
        "prove-account",
        "prove-storage",
        "prove-call"
      ]
    },
    "claim": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "chain_identity",
            "tx_succeeded",
            "contract_exists",
            "account_state",
            "storage_value",
            "call_result"
          ]
        }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object"
    },
    "conclusion": {
      "type": "object",
      "required": [
        "verified",
        "summary"
      ],
      "properties": {
        "verified": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "packHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}
